# ВНИМАНИЕ: в NODE_ENV=production приложение НЕ СТАРТУЕТ, если переменная
# отсутствует или указывает на localhost (src/config/env.validation.ts).
# Это сделано намеренно: раньше пропущенная переменная молча подставляла
# localhost, и все три сервиса падали без объяснения причин.
# Значения для прода — в панели Render, здесь только имена.

# ---- App ----
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# ---- PostgreSQL ----
POSTGRES_USER=ig
POSTGRES_PASSWORD=ig_password
POSTGRES_DB=instagram
DATABASE_URL=postgresql://ig:ig_password@localhost:5433/instagram?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- JWT ----
JWT_SECRET=change_me_access_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# ---- S3 / MinIO ----
S3_ENDPOINT=localhost
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=instagram
# Публичный домен медиа: из него собираются avatarUrl, media[].url и т.д.
# В БД лежит КЛЮЧ, ссылка строится при отдаче — смена домена не ломает записи.
S3_PUBLIC_URL=http://localhost:9000/instagram

# ---- SMTP ----
# Код в MailService один и тот же — режим переключается ТОЛЬКО этими переменными.
# Если SMTP_USER пуст → auth не отправляется (MailHog его и не требует).

# dev (MailHog): письма никуда не уходят, читаются на http://localhost:8025
# SMTP_HOST=localhost — если API запущен локально (npm run start:dev)
# SMTP_HOST=mailhog   — если API запущен внутри docker compose (подставляется автоматически)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# prod (Gmail App Password) — раскомментировать и заполнить, код менять НЕ нужно:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=myapp@gmail.com
# SMTP_PASS=<16-значный App Password из Google, НЕ пароль от аккаунта>

SMTP_FROM="Instagram <no-reply@instagram.local>"

# ---- LiveKit ----
# В проде обязателен wss:// (не ws://): фронт работает по https, браузер
# заблокирует незащищённый сокет. Проверяется валидацией конфига.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# ---- Spotify (Client Credentials Flow) ----
# Ключи из https://developer.spotify.com/dashboard (Client ID + Client Secret).
# Secret — как пароль: только здесь, никогда в коде и не в git.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ---- Limits ----
MAX_IMAGE_MB=10
MAX_VIDEO_MB=100
MAX_AUDIO_MB=20
