# ---- App ----
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# ---- PostgreSQL ----
POSTGRES_USER=ig
POSTGRES_PASSWORD=ig_password
POSTGRES_DB=instagram
DATABASE_URL=postgresql://ig:ig_password@localhost:5432/instagram?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- JWT ----
JWT_SECRET=change_me_access_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# ---- S3 / MinIO ----
S3_ENDPOINT=localhost
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=instagram
S3_PUBLIC_URL=http://localhost:9000/instagram

# ---- SMTP (Mailtrap in dev) ----
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Instagram <no-reply@instagram.local>"

# ---- LiveKit ----
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# ---- Limits ----
MAX_IMAGE_MB=10
MAX_VIDEO_MB=100
MAX_AUDIO_MB=20
