# Что НЕ отправлять в build context.
#
# Без этого файла `COPY . .` тащил в демон весь каталог — 1.4 ГБ: node_modules
# (1.2 ГБ с бинарями sharp/ffmpeg), assets/music (175 МБ mp3) и .git. Отсюда и
# бралась «сборка зависает >40 минут»: время уходило не на сборку, а на передачу
# контекста. Ничего из этого в образе не нужно: зависимости ставит `npm ci`
# внутри, музыка живёт в S3.

# Зависимости — ставятся внутри образа под его платформу
node_modules
*/node_modules

# Артефакты сборки — собираются внутри
dist
build
coverage
.next

# История git в рантайме не нужна
.git
.gitignore
.github

# 175 МБ mp3: сиды/импорт музыки, в контейнере не используются
assets

# Секреты. .env и так в .gitignore, но контекст берётся с диска, а не из git —
# без этой строки локальный .env уехал бы в образ.
.env
.env.*
!.env.example

# Тесты и служебные скрипты: в продовом образе не запускаются
test
scripts
*.spec.ts
*.e2e-spec.ts

# Документация
docs
*.md
!README.md

# IDE / ОС
.vscode
.idea
.DS_Store
Thumbs.db

# Логи и временное
*.log
npm-debug.log*
tmp
temp

# Docker-файлы сами в образе не нужны
Dockerfile*
docker-compose*.yml
.dockerignore
