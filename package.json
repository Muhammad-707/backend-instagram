{
  "name": "instagram-backend",
  "version": "0.1.0",
  "description": "Instagram clone backend — NestJS + Prisma + PostgreSQL",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:format": "prisma format",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "ts-node prisma/seed.ts",
    "demo:seed": "ts-node scripts/demo-seed.ts",
    "music:import": "ts-node -r dotenv/config scripts/music-import.ts",
    "swagger:export": "ts-node -r dotenv/config scripts/export-swagger.ts",
    "endpoints:report": "ts-node scripts/endpoints-report.ts",
    "er:diagram": "ts-node scripts/er-diagram.ts",
    "smoke": "ts-node scripts/smoke.ts",
    "contract:check": "ts-node scripts/contract-check.ts",
    "socket:check": "ts-node scripts/socket-check.ts",
    "live:check": "ts-node scripts/live-check.ts",
    "group:check": "ts-node scripts/group-check.ts",
    "notes:check": "ts-node scripts/notes-check.ts",
    "nextauth:check": "ts-node scripts/nextauth-check.ts",
    "calls:check": "ts-node scripts/calls-check.ts",
    "live:media": "ts-node -r dotenv/config scripts/live-media-check.ts",
    "turn:check": "ts-node -r dotenv/config scripts/turn-check.ts",
    "online:check": "ts-node scripts/online-music-check.ts",
    "s3:check": "ts-node scripts/s3-check.ts",
    "livekit:check": "ts-node scripts/livekit-check.ts",
    "verify:all": "npm run lint && npm run build && npm run test && npm run test:e2e && npm run smoke && npm run contract:check && npm run socket:check && npm run live:check && npm run group:check && npm run notes:check && npm run calls:check && npm run live:media && npm run turn:check && npm run online:check"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.0.1",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.0.1",
    "@prisma/client": "^6.11.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.56.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.4.2",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "file-type": "^16.5.4",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "joi": "^18.2.3",
    "livekit-server-sdk": "^2.13.1",
    "minio": "^8.0.5",
    "nodemailer": "^7.0.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^6.11.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.3",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/ffprobe-static": "^2.0.3",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "socket.io-client": "^4.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.64.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
